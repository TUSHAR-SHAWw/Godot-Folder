[gd_scene load_steps=2 format=3 uid="uid://bkv0olj76dums"]

[sub_resource type="GDScript" id="GDScript_hj4jo"]
script/source = "extends Area2D
@onready var timer: Timer = $Timer

@onready var asp: AnimatedSprite2D = $AnimatedSprite2D

	
func _on_body_entered(body: Node2D) -> void:
	Engine.time_scale=0.5
	#for i in range(20):
		#await get_tree().create_timer(0.5).timeout
		#body.position.y+=i
	body.get_node(\"CollisionShape2D\").queue_free()
	
	timer.start()


func _on_timer_timeout() -> void:
	Engine.time_scale=1
	#get_tree().reload_current_scene()
	get_tree().change_scene_to_file(\"res://scenes/menu.tscn\")
"

[node name="KILLAREA" type="Area2D"]
collision_mask = 2
script = SubResource("GDScript_hj4jo")

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]

[node name="Timer" type="Timer" parent="."]
one_shot = true

[connection signal="body_entered" from="." to="." method="_on_body_entered"]
[connection signal="timeout" from="Timer" to="." method="_on_timer_timeout"]
